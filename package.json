    "lucide-react-native": "^1.16.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-native": "^0.85.3",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "babel-preset-expo": "~56.0.0"
  }
